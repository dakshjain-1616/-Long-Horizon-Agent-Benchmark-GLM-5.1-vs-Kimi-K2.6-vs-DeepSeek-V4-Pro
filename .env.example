# Long-Horizon Agent Benchmark — Environment Variables

# ---------------------------------------------------------------------------
# Inference (set ONE of these — OpenRouter is recommended)
# ---------------------------------------------------------------------------

# Recommended: OpenRouter — single key for GLM-5.1, Kimi-K2.6, DeepSeek V4-Pro
# (and many more frontier models). https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Alternative direct keys (only needed if you skip OpenRouter):
# GLM_API_KEY=your_glm_api_key_here          # https://open.bigmodel.cn
# KIMI_API_KEY=your_kimi_api_key_here        # https://platform.moonshot.cn
# DEEPSEEK_API_KEY=your_deepseek_api_key_here # https://platform.deepseek.com

# Optional: override base URLs (defaults pick OpenRouter when its key is set).
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Benchmark Configuration
LHB_MOCK_MODE=false
LHB_MAX_ITERATIONS=100
LHB_TIMEOUT_SECONDS=300
LHB_OUTPUT_DIR=outputs
LHB_DATASET_DIR=datasets

# Logging
LOG_LEVEL=INFO
LOG_FILE=outputs/benchmark.log
